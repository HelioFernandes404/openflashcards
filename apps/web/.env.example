# OpenFlashcards Web - Environment Variables

# API URL for local development (include /api/v1 suffix)
# In Docker/production the frontend prefers /runtime-config.js generated at container startup.
# To use the real API locally, start the Go API on port 3030 (cd apps/api && make run).
VITE_API_URL=http://localhost:3030/api/v1

# API Configuration (optional)
# VITE_API_TIMEOUT=10000
# VITE_API_RETRY_ATTEMPTS=3
# VITE_API_RETRY_DELAY=1000
# VITE_ENABLE_LOGGING=true is set in deploy/docker-compose.vps.yml and web-deploy CI.

# Runtime container variables (documentation)
# OPENFLASHCARDS_API_URL=http://localhost:3030/api/v1
# OPENFLASHCARDS_API_TIMEOUT=10000
# OPENFLASHCARDS_API_RETRY_ATTEMPTS=3
# OPENFLASHCARDS_API_RETRY_DELAY=1000
